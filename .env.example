# ──────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────
# PostgreSQL connection URL (used by Spring Boot)
DB_URL=jdbc:postgresql://localhost:5432/jobboard

# PostgreSQL username
DB_USERNAME=postgres

# PostgreSQL password
DB_PASSWORD=your_secure_password_here

# ──────────────────────────────────────────────
# JWT Configuration
# ──────────────────────────────────────────────
# Secret key for signing JWT tokens (min 256-bit / 32 chars)
# IMPORTANT: Generate a strong random key for production
JWT_SECRET=your_jwt_secret_key_min_32_characters_long

# ──────────────────────────────────────────────
# Mail Configuration (SMTP)
# ──────────────────────────────────────────────
# SMTP server hostname (e.g., smtp.gmail.com)
MAIL_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
MAIL_PORT=587

# SMTP username / sender email address
MAIL_USERNAME=your_email@gmail.com

# SMTP password or app-specific password
MAIL_PASSWORD=your_email_app_password

# ──────────────────────────────────────────────
# Frontend Configuration
# ──────────────────────────────────────────────
# Backend API base URL used by the React frontend
VITE_API_URL=http://localhost:8080/api

# Frontend URL (used in email links for password reset and email verification)
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# File Upload Configuration
# ──────────────────────────────────────────────
# Directory for storing uploaded resume files
FILE_UPLOAD_DIR=uploads/resumes

# ──────────────────────────────────────────────
# CORS Configuration
# ──────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,http://localhost:5173,https://jobboard.example.com
CORS_ORIGINS=http://localhost:5173
